{
  "name": "musictheorylab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "extract-legacy": "node scripts/extract-legacy.mjs",
    "predev": "npm run extract-legacy",
    "dev": "vite",
    "prebuild": "npm run extract-legacy",
    "build": "tsc -b && vite build",
    "cf:deploy": "npm run build && wrangler deploy",
    "cf:preview": "npm run build && wrangler dev",
    "preview": "vite preview",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "puppeteer-core": "^24.41.0",
    "typescript": "^5.9.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.0"
  }
}
